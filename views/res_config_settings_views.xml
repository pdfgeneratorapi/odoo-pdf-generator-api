<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pdfgen</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="PDF Generator API"
                     string="PDF Generator API"
                     name="pdfgeneratorapi_connector"
                     groups="base.group_system">
                    <block title="PDF Generator API" name="pdfgen_settings_block">
                        <setting id="pdfgen_credentials"
                                 string="Credentials"
                                 help="Provided by pdfgeneratorapi.com. Admins only.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="pdfgen_api_base_url" class="col-lg-3"/>
                                    <field name="pdfgen_api_base_url" class="col-lg-9"/>
                                </div>
                                <div class="row mt16">
                                    <label for="pdfgen_api_key" class="col-lg-3"/>
                                    <field name="pdfgen_api_key" class="col-lg-9"/>
                                </div>
                                <div class="row mt16">
                                    <label for="pdfgen_api_secret" class="col-lg-3"/>
                                    <field name="pdfgen_api_secret" class="col-lg-9" password="True"/>
                                </div>
                                <div class="row mt16">
                                    <label for="pdfgen_workspace_identifier" class="col-lg-3"/>
                                    <field name="pdfgen_workspace_identifier" class="col-lg-9"/>
                                </div>
                                <div class="mt16">
                                    <button name="action_pdfgen_test_connection"
                                            type="object"
                                            string="Test Connection"
                                            class="btn-secondary"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_pdfgen_settings" model="ir.actions.act_window">
        <field name="name">PDF Generator API</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'pdfgeneratorapi_connector'}</field>
    </record>
</odoo>
