<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_pdfgen" model="ir.ui.view">
        <field name="name">account.move.form.pdfgen</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <div class="btn-group" invisible="not pdfgen_configured">
                    <button name="action_open_pdfgen_wizard"
                            type="object"
                            string="Generate custom PDF"
                            class="btn btn-primary"/>
                    <button type="button"
                            class="btn btn-primary dropdown-toggle dropdown-toggle-split"
                            data-bs-toggle="dropdown"
                            aria-expanded="false">
                        <span class="visually-hidden">Toggle dropdown</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end" role="menu">
                        <button name="action_open_pdfgen_wizard"
                                type="object"
                                string="Generate and Download"
                                context="{'default_auto_download': True}"
                                class="dropdown-item"/>
                    </div>
                </div>
            </xpath>
            <xpath expr="//header" position="before">
                <field name="pdfgen_configured" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- Invoice lists: surface the same Generate custom PDF action in the
         header toolbar. Only fires for a single selection; the mixin method
         shows a friendly hint when more rows are picked.

         Extends the shared `account.view_invoice_tree` base rather than
         `view_out_invoice_tree`: customer invoices, vendor bills and credit
         notes are all `mode="primary"` children of it, and a primary view
         resolves its parent's arch (extensions included) before layering its
         own — so the base reaches all three, where the out-invoice leaf
         reached only Customer Invoices. Journal Entries hang off a separate
         root (`account.view_move_tree`) and are deliberately untouched.
         Odoo extends this same base in `sale.account_invoice_view_tree`. -->
    <record id="view_out_invoice_list_pdfgen" model="ir.ui.view">
        <field name="name">account.move.list.pdfgen</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button name="action_open_pdfgen_wizard_from_list"
                            type="object"
                            string="Generate custom PDF"
                            class="btn-primary"/>
                    <button name="action_view_pdfgen_async_jobs_from_list"
                            type="object"
                            string="View Async Jobs"
                            class="btn-secondary"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
