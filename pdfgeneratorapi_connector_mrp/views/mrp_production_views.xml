<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_form_view_pdfgen" model="ir.ui.view">
        <field name="name">mrp.production.form.pdfgen</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <div class="btn-group" invisible="not pdfgen_configured">
                    <button name="action_open_pdfgen_wizard"
                            type="object"
                            string="Generate custom PDF"
                            class="btn btn-primary"/>
                    <button name="pdfgen_dropdown_toggle"
                            type="button"
                            class="btn btn-primary dropdown-toggle dropdown-toggle-split"
                            data-bs-toggle="dropdown"
                            aria-expanded="false">
                        <span class="visually-hidden">Toggle dropdown</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end" role="menu">
                        <button name="action_open_pdfgen_wizard"
                                type="object"
                                string="Generate and Download"
                                context="{'default_auto_download': True}"
                                class="dropdown-item"/>
                    </div>
                </div>
                <field name="pdfgen_configured" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="mrp_production_list_view_pdfgen" model="ir.ui.view">
        <field name="name">mrp.production.list.pdfgen</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <header>
                    <button name="action_open_pdfgen_wizard_from_list"
                            type="object"
                            string="Generate custom PDF"
                            class="btn-primary"/>
                    <button name="action_view_pdfgen_async_jobs_from_list"
                            type="object"
                            string="View Async Jobs"
                            class="btn-secondary"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
