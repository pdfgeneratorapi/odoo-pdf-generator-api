<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_pdfgen" model="ir.ui.view">
        <field name="name">sale.order.form.pdfgen</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <div class="btn-group" invisible="not pdfgen_configured">
                    <button name="action_open_pdfgen_wizard"
                            type="object"
                            string="Generate custom PDF"
                            class="btn btn-primary"/>
                    <button name="pdfgen_dropdown_toggle"
                            type="button"
                            class="btn btn-primary dropdown-toggle dropdown-toggle-split"
                            data-bs-toggle="dropdown"
                            aria-expanded="false">
                        <span class="visually-hidden">Toggle dropdown</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end" role="menu">
                        <button name="action_open_pdfgen_wizard"
                                type="object"
                                string="Generate and Download"
                                context="{'default_auto_download': True}"
                                class="dropdown-item"/>
                    </div>
                </div>
                <field name="pdfgen_configured" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- Extend the shared base (`sale.sale_order_tree`), not `view_order_tree`.
         Sales has two sibling list branches — orders and quotations — both
         `mode="primary"` children of the base. A primary view resolves its
         parent's arch *with extensions applied* before layering its own, so
         extending the base reaches both; extending `view_order_tree` reached
         only Sales > Orders and left Quotations (the default landing view,
         via view_quotation_tree_with_onboarding) without the button. -->
    <record id="view_order_list_pdfgen" model="ir.ui.view">
        <field name="name">sale.order.list.pdfgen</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button name="action_open_pdfgen_wizard_from_list"
                            type="object"
                            string="Generate custom PDF"
                            class="btn-primary"/>
                    <button name="action_view_pdfgen_async_jobs_from_list"
                            type="object"
                            string="View Async Jobs"
                            class="btn-secondary"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
