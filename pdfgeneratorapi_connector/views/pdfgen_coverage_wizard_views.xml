<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pdfgen_coverage_wizard_form" model="ir.ui.view">
        <field name="name">pdfgen.coverage.wizard.form</field>
        <field name="model">pdfgen.coverage.wizard</field>
        <field name="arch" type="xml">
            <form string="Check template coverage">
                <sheet>
                    <group>
                        <field name="dataset_id" readonly="1"/>
                        <field name="template_id"/>
                        <field name="template_name" invisible="not checked" readonly="1"/>
                    </group>

                    <div invisible="not checked" class="mt-3">
                        <div class="alert"
                             t-attf-class="alert-#{coverage_total and coverage_matched == coverage_total and 'success' or (coverage_matched and 'warning' or 'danger')}"
                             role="alert">
                            <h3 class="mb-1">
                                <field name="coverage_matched"/>
                                <span> / </span>
                                <field name="coverage_total"/>
                                <span> placeholders covered</span>
                            </h3>
                            <p class="mb-0" invisible="coverage_total and coverage_matched == coverage_total">
                                The template references placeholders your dataset doesn't map. See
                                <strong>Missing</strong> below — add those to the dataset or pick a different template.
                            </p>
                            <p class="mb-0" invisible="not coverage_total or coverage_matched != coverage_total">
                                Every placeholder the template references is mapped by this dataset. Generation should work.
                            </p>
                        </div>

                        <div class="row mt-3">
                            <div class="col-12 col-md-6">
                                <label for="missing_placeholders" class="fw-bold text-danger">Missing from dataset</label>
                                <field name="missing_placeholders"
                                       widget="text"
                                       readonly="1"
                                       nolabel="1"
                                       placeholder="None — the dataset covers everything the template needs."/>
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="extra_placeholders" class="fw-bold text-muted">Unused by template</label>
                                <field name="extra_placeholders"
                                       widget="text"
                                       readonly="1"
                                       nolabel="1"
                                       placeholder="None — every dataset field is referenced by the template."/>
                            </div>
                        </div>
                    </div>

                    <field name="checked" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_check"
                            type="object"
                            string="Check"
                            class="btn-primary"
                            invisible="not template_id"/>
                    <button special="cancel"
                            string="Close"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pdfgen_coverage_wizard" model="ir.actions.act_window">
        <field name="name">Check template coverage</field>
        <field name="res_model">pdfgen.coverage.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
