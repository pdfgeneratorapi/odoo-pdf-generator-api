<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pdfgen</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="PDF Generator API"
                     string="PDF Generator API"
                     name="pdfgeneratorapi_connector"
                     groups="base.group_system">
                    <!-- Each section is a native <details>/<summary> with the title rendered
                         as an <h2> so it inherits Odoo's `.app_settings_block h2` gray-bar
                         styling. The show/hide toggle on the right of the header swaps via
                         the [open] selector in settings.scss. Credentials is open by default;
                         the rest start collapsed to keep the panel scannable. -->
                    <details class="pdfgen_collapsible_details" name="pdfgen_credentials_block" open="open">
                        <summary>
                            <h2 class="d-flex justify-content-between align-items-center m-0">
                                <span>Credentials</span>
                                <span class="pdfgen_collapsible_toggle text-primary small fw-normal">
                                    <span class="pdfgen_collapsible_show">Show <i class="fa fa-chevron-right"/></span>
                                    <span class="pdfgen_collapsible_hide">Hide <i class="fa fa-chevron-down"/></span>
                                </span>
                            </h2>
                        </summary>
                        <h3 class="o_setting_tip text-muted">Provided by pdfgeneratorapi.com. Admins only.</h3>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 mb-4">
                                <label for="pdfgen_api_key" class="o_form_label fw-bold" string="API Key"/>
                                <div class="text-muted small mb-2">Public API key from your pdfgeneratorapi.com account.</div>
                                <div class="col-lg-9 col-12 ps-0">
                                    <field name="pdfgen_api_key" class="w-100"/>
                                </div>
                            </div>
                            <div class="col-12 mb-4">
                                <label for="pdfgen_api_secret" class="o_form_label fw-bold" string="API Secret"/>
                                <div class="text-muted small mb-2">Signs JWT tokens. Keep this confidential.</div>
                                <div class="col-lg-9 col-12 ps-0">
                                    <div class="d-flex align-items-center gap-3 w-100">
                                        <div class="flex-grow-1">
                                            <field name="pdfgen_api_secret"
                                                   password="True"
                                                   invisible="pdfgen_show_secret"
                                                   class="w-100"/>
                                            <field name="pdfgen_api_secret"
                                                   invisible="not pdfgen_show_secret"
                                                   class="w-100"/>
                                        </div>
                                        <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                            <field name="pdfgen_show_secret"
                                                   widget="boolean_toggle"
                                                   nolabel="1"
                                                   options="{'autosave': False}"/>
                                            <span class="text-muted small text-nowrap">
                                                <i class="fa fa-eye me-1" invisible="pdfgen_show_secret"/>
                                                <i class="fa fa-eye-slash me-1" invisible="not pdfgen_show_secret"/>
                                                <span invisible="pdfgen_show_secret">Show</span>
                                                <span invisible="not pdfgen_show_secret">Hide</span>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 mb-4">
                                <label for="pdfgen_workspace_identifier" class="o_form_label fw-bold" string="Workspace Identifier"/>
                                <div class="text-muted small mb-2">Account email for regular workspaces, or the sub-workspace identifier.</div>
                                <div class="col-lg-9 col-12 ps-0">
                                    <field name="pdfgen_workspace_identifier" class="w-100"/>
                                </div>
                            </div>
                            <div class="col-12 mb-4">
                                <div class="o_form_label fw-bold">Test the connection</div>
                                <div class="text-muted small mb-2">Sends an authenticated request to verify credentials and workspace identity.</div>
                                <button name="action_pdfgen_test_connection"
                                        type="object"
                                        string="Test Connection"
                                        class="btn-primary"/>
                            </div>
                        </div>
                    </details>
                    <details class="pdfgen_collapsible_details" name="pdfgen_document_types_block" open="open">
                        <summary>
                            <h2 class="d-flex justify-content-between align-items-center m-0">
                                <span>Document types</span>
                                <span class="pdfgen_collapsible_toggle text-primary small fw-normal">
                                    <span class="pdfgen_collapsible_show">Show <i class="fa fa-chevron-right"/></span>
                                    <span class="pdfgen_collapsible_hide">Hide <i class="fa fa-chevron-down"/></span>
                                </span>
                            </h2>
                        </summary>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 mb-2">
                                <div class="text-muted small mb-3">
                                    Enable the document types you want to generate PDFs for. Each one adds a Generate custom PDF button on its records and a starter placeholder dataset you can customise.
                                </div>
                            </div>
                            <div class="col-12 mb-3">
                                <field name="module_pdfgeneratorapi_connector_account" widget="boolean_toggle"/>
                                <label for="module_pdfgeneratorapi_connector_account"/>
                                <div class="text-muted small">Customer invoices, vendor bills, and credit notes. Also enables the Use pdfgen PDF toggle on the invoice Send wizard.</div>
                            </div>
                            <div class="col-12 mb-3">
                                <field name="module_pdfgeneratorapi_connector_sale" widget="boolean_toggle"/>
                                <label for="module_pdfgeneratorapi_connector_sale"/>
                                <div class="text-muted small">Quotations and sale orders.</div>
                            </div>
                            <div class="col-12 mb-3">
                                <field name="module_pdfgeneratorapi_connector_purchase" widget="boolean_toggle"/>
                                <label for="module_pdfgeneratorapi_connector_purchase"/>
                                <div class="text-muted small">Purchase orders sent to vendors.</div>
                            </div>
                            <div class="col-12 mb-3">
                                <field name="module_pdfgeneratorapi_connector_stock" widget="boolean_toggle"/>
                                <label for="module_pdfgeneratorapi_connector_stock"/>
                                <div class="text-muted small">Delivery slips and goods receipts.</div>
                            </div>
                            <div class="col-12 mb-3">
                                <field name="module_pdfgeneratorapi_connector_mrp" widget="boolean_toggle"/>
                                <label for="module_pdfgeneratorapi_connector_mrp"/>
                                <div class="text-muted small">Manufacturing orders / work orders.</div>
                            </div>
                            <div class="col-12 mb-3">
                                <field name="module_pdfgeneratorapi_connector_rental" widget="boolean_toggle"/>
                                <label for="module_pdfgeneratorapi_connector_rental"/>
                                <div class="text-muted small">Rental orders (contracts, pickup/return slips). Enables the Sales bridge automatically.</div>
                            </div>
                        </div>
                    </details>
                    <details class="pdfgen_collapsible_details" name="pdfgen_advanced_block">
                        <summary>
                            <h2 class="d-flex justify-content-between align-items-center m-0">
                                <span>Advanced Settings</span>
                                <span class="pdfgen_collapsible_toggle text-primary small fw-normal">
                                    <span class="pdfgen_collapsible_show">Show <i class="fa fa-chevron-right"/></span>
                                    <span class="pdfgen_collapsible_hide">Hide <i class="fa fa-chevron-down"/></span>
                                </span>
                            </h2>
                        </summary>
                        <h3 class="o_setting_tip text-muted">Override the default API endpoint and the template editor's browser URL. Most users can leave these blank.</h3>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 mb-4">
                                <label for="pdfgen_api_base_url" class="o_form_label fw-bold" string="API Base URL"/>
                                <div class="text-muted small mb-2">Regional endpoint. Default: us1.pdfgeneratorapi.com.</div>
                                <div class="col-lg-9 col-12 ps-0">
                                    <field name="pdfgen_api_base_url" class="w-100"/>
                                </div>
                            </div>
                            <div class="col-12 mb-4">
                                <label for="pdfgen_editor_web_url" class="o_form_label fw-bold" string="Editor Web URL (optional)"/>
                                <div class="text-muted small mb-2">
                                    Override for the template editor's browser URL. Leave empty to derive from API Base URL.
                                    Set this when Odoo reaches the API via a hostname the browser can't resolve
                                    (Docker service name, private VPC endpoint, …) or when your company runs a dedicated
                                    PDF Generator API deployment on its own domain. Example: <code>https://mydomain.com/editor</code>.
                                </div>
                                <div class="col-lg-9 col-12 ps-0">
                                    <field name="pdfgen_editor_web_url" class="w-100" placeholder="e.g. https://mydomain.com/editor"/>
                                </div>
                            </div>
                        </div>
                    </details>
                    <details class="pdfgen_collapsible_details" name="pdfgen_attachments_block">
                        <summary>
                            <h2 class="d-flex justify-content-between align-items-center m-0">
                                <span>Attachments</span>
                                <span class="pdfgen_collapsible_toggle text-primary small fw-normal">
                                    <span class="pdfgen_collapsible_show">Show <i class="fa fa-chevron-right"/></span>
                                    <span class="pdfgen_collapsible_hide">Hide <i class="fa fa-chevron-down"/></span>
                                </span>
                            </h2>
                        </summary>
                        <h3 class="o_setting_tip text-muted">Control what happens to previously-generated PDFs when a user clicks Generate again on the same record.</h3>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 mb-4">
                                <div class="o_form_label fw-bold">Cleanup policy</div>
                                <div class="text-muted small mb-2">Keep: every generation adds a new attachment. Replace: pdfgen-generated PDFs on that record are deleted first. Manually uploaded PDFs are never touched.</div>
                                <field name="pdfgen_attachment_cleanup" widget="radio"/>
                            </div>
                        </div>
                    </details>
                    <details class="pdfgen_collapsible_details" name="pdfgen_webhook_block">
                        <summary>
                            <h2 class="d-flex justify-content-between align-items-center m-0">
                                <span>Async webhook</span>
                                <span class="pdfgen_collapsible_toggle text-primary small fw-normal">
                                    <span class="pdfgen_collapsible_show">Show <i class="fa fa-chevron-right"/></span>
                                    <span class="pdfgen_collapsible_hide">Hide <i class="fa fa-chevron-down"/></span>
                                </span>
                            </h2>
                        </summary>
                        <h3 class="o_setting_tip text-muted">Where pdfgeneratorapi.com calls back when an async generation finishes. Required for the multi-record list-view dispatch flow.</h3>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 mb-4">
                                <label for="pdfgen_webhook_base_url" class="o_form_label fw-bold" string="Webhook Base URL"/>
                                <div class="text-muted small mb-2">
                                    Public origin (scheme + host) of this Odoo so pdfgeneratorapi.com can reach
                                    <code>/pdfgen/webhook/deliver</code>. Leave blank to fall back to the system parameter
                                    <code>web.base.url</code>. For local dev, point this at your ngrok tunnel.
                                </div>
                                <div class="col-lg-9 col-12 ps-0">
                                    <field name="pdfgen_webhook_base_url" class="w-100" placeholder="e.g. https://abcd-1234.ngrok-free.app"/>
                                </div>
                            </div>
                            <div class="col-12 mb-4">
                                <label for="pdfgen_webhook_secret" class="o_form_label fw-bold" string="Webhook Secret"/>
                                <div class="text-muted small mb-2">
                                    Signs each callback URL with an HMAC-derived per-job token. Auto-filled with a 32-byte random
                                    value on first save when blank — only rotate if you suspect leakage.
                                </div>
                                <div class="col-lg-9 col-12 ps-0">
                                    <div class="d-flex align-items-center gap-3 w-100">
                                        <div class="flex-grow-1">
                                            <field name="pdfgen_webhook_secret"
                                                   password="True"
                                                   invisible="pdfgen_show_webhook_secret"
                                                   class="w-100"
                                                   placeholder="auto-generated on save"/>
                                            <field name="pdfgen_webhook_secret"
                                                   invisible="not pdfgen_show_webhook_secret"
                                                   class="w-100"
                                                   placeholder="auto-generated on save"/>
                                        </div>
                                        <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                            <field name="pdfgen_show_webhook_secret"
                                                   widget="boolean_toggle"
                                                   nolabel="1"
                                                   options="{'autosave': False}"/>
                                            <span class="text-muted small text-nowrap">
                                                <i class="fa fa-eye me-1" invisible="pdfgen_show_webhook_secret"/>
                                                <i class="fa fa-eye-slash me-1" invisible="not pdfgen_show_webhook_secret"/>
                                                <span invisible="pdfgen_show_webhook_secret">Show</span>
                                                <span invisible="not pdfgen_show_webhook_secret">Hide</span>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </details>
                    <!-- Mirror the top-bar Save/Discard so users don't have to scroll back up
                         after editing the (long) PDF Generator API settings panel. -->
                    <div class="d-flex gap-2 justify-content-end py-3 px-3 border-top mt-3">
                        <button name="cancel" type="object" string="Discard" class="btn btn-secondary"/>
                        <button name="execute" type="object" string="Save" class="btn btn-primary"/>
                    </div>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_pdfgen_settings" model="ir.actions.act_window">
        <field name="name">PDF Generator API</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'pdfgeneratorapi_connector'}</field>
    </record>
</odoo>
