<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pdfgeneratorapi_connector.FieldPalette">
        <div class="o_pdfgen_palette d-flex flex-column"
             tabindex="-1"
             t-on-keydown="onKeyDown">
            <div class="o_pdfgen_palette_header px-2 pt-2 pb-1">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="fa fa-sitemap text-muted"/>
                    <strong>Field palette</strong>
                    <small class="text-muted ms-auto">drag onto a row</small>
                </div>
                <nav t-if="breadcrumb.length" aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2 small">
                        <li t-foreach="breadcrumb" t-as="crumb" t-key="crumb_index"
                            t-att-class="'breadcrumb-item' + (crumb_index === breadcrumb.length - 1 ? ' active' : '')">
                            <a t-if="crumb_index !== breadcrumb.length - 1" href="#"
                               t-on-click.prevent="() => this.onBreadcrumbClick(crumb_index)">
                                <t t-esc="crumb.label"/>
                            </a>
                            <span t-else="" t-esc="crumb.label"/>
                        </li>
                    </ol>
                </nav>
                <input type="text" class="form-control form-control-sm"
                       placeholder="Filter fields…"
                       t-ref="filter"
                       t-model="state.search"/>
                <div class="text-muted small mt-1 o_pdfgen_palette_hint">
                    <i class="fa fa-keyboard-o me-1"/>
                    <span>↑↓ navigate · Enter drills in · Esc back · / filter</span>
                </div>
            </div>
            <div class="o_pdfgen_palette_body flex-grow-1 overflow-auto px-2 pb-2"
                 t-ref="list">
                <div t-if="state.loading" class="text-center text-muted py-3">
                    <i class="fa fa-spinner fa-spin"/>
                </div>
                <div t-elif="!filteredFields.length" class="text-center text-muted py-3 small">
                    No fields match.
                </div>
                <ul t-else="" class="list-unstyled mb-0">
                    <li t-foreach="filteredFields" t-as="field" t-key="field.name"
                        t-att-class="'o_pdfgen_palette_item d-flex align-items-center gap-2 py-1 px-2 rounded' + (field_index === state.focusIndex ? ' o_pdfgen_palette_item_focused' : '')"
                        tabindex="0"
                        t-on-pointerdown="(ev) => this.onPointerDown(ev, field)"
                        t-on-focus="() => this.onItemFocus(field_index)"
                        t-on-dblclick="() => field.isRelation ? this.onDrillIn(field) : null">
                        <i t-att-class="'fa fa-' + (field.isRelation ? 'link' : 'circle-o') + ' text-muted small'"/>
                        <div class="flex-grow-1 lh-sm">
                            <div class="fw-semibold" t-esc="field.string"/>
                            <small class="text-muted">
                                <t t-esc="field.name"/> · <t t-esc="field.ttype"/>
                                <t t-if="field.isRelation"> → <t t-esc="field.relation"/></t>
                            </small>
                        </div>
                        <button t-if="field.isRelation"
                                class="btn btn-sm btn-link py-0 px-1"
                                t-on-click="() => this.onDrillIn(field)"
                                title="Browse related fields">
                            <i class="fa fa-chevron-right"/>
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    </t>

    <t t-name="pdfgeneratorapi_connector.DroppableFieldSelector"
       t-inherit="web.DynamicModelFieldSelectorChar" t-inherit-mode="primary">
        <!-- Wrap the stock dynamic field selector in a drop target. Inheriting
             the stock template (rather than re-implementing it) keeps the
             hidden CharField input that DynamicModelFieldSelectorChar's setup
             relies on. -->
        <xpath expr="//DynamicModelFieldSelector" position="replace">
            <div class="o_pdfgen_droppable" t-ref="root">
                <DynamicModelFieldSelector t-props="getSelectorProps"/>
            </div>
        </xpath>
    </t>

</templates>
