msgstr "Název nové šablony"

msgid "No active dataset found for %s. Create one under PDF Generator API > Field Datasets."
msgstr "Nebyla nalezena aktivní datová sada pro %s. Vytvořte jednu v PDF Generator API > Datové sady polí."

msgid "No fields match."
msgstr "Žádné pole neodpovídá."

msgid "None — every dataset field is referenced by the template."
msgstr "Žádné — šablona odkazuje na každé pole datové sady."

msgid "None — the dataset covers everything the template needs."
msgstr "Žádné — datová sada pokrývá vše, co šablona potřebuje."

