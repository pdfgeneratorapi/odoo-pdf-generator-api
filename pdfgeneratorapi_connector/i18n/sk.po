msgstr "Webová URL editora (voliteľné)"

msgid "Editor closed."
msgstr "Editor zatvorený."

msgid "Embed the pdfgeneratorapi.com template editor"
msgstr "Vložiť editor šablón pdfgeneratorapi.com"

msgid "Every placeholder the template references is mapped by this dataset. Generation should work."
msgstr "Každý zástupný symbol, na ktorý šablóna odkazuje, je mapovaný touto dátovou sadou. Generovanie by malo fungovať."

msgid "Expose the PDF Generator wizard on a document model"
msgstr "Sprístupniť sprievodcu PDF Generator na modeli dokumentu"

msgid "Expression"
msgstr "Výraz"

msgid "Field Dataset"
msgstr "Dátová sada polí"

msgid "Field Datasets"
msgstr "Dátové sady polí"

msgid "Field Mappings"
msgstr "Mapovania polí"

msgid "Field palette"
msgstr "Paleta polí"

msgid "Filter fields…"
msgstr "Filtrovať polia…"

msgid "For children of a list placeholder, the list line."
msgstr "Pre potomkov zástupného symbolu typu zoznam: riadok zoznamu."

msgid "Generate"
msgstr "Generovať"

msgid "Generate PDF via pdfgeneratorapi.com"
msgstr "Vygenerovať PDF cez pdfgeneratorapi.com"

msgid "Generate custom PDF"
msgstr "Vygenerovať vlastné PDF"

msgid "Generated custom PDF via pdfgeneratorapi.com."
msgstr "Vlastné PDF vygenerované cez pdfgeneratorapi.com."

msgid "HTML render of the selected template with a sample record's data. Useful to sanity-check the template + dataset combination without generating a PDF."
msgstr "HTML vykreslenie vybranej šablóny s údajmi vzorového záznamu. Užitočné na overenie kombinácie šablóna + dátová sada bez generovania PDF."

msgid "ID"
msgstr "ID"

msgid "Is List"
msgstr "Je zoznam"

msgid "Journal Entry"
msgstr "Účtovný zápis"

msgid "Keep all versions"
msgstr "Ponechať všetky verzie"

msgid "Keep: every generation adds a new attachment. Replace: pdfgen-generated PDFs on that record are deleted first. Manually uploaded PDFs are never touched."
msgstr "Ponechať: každé generovanie pridá novú prílohu. Nahradiť: PDF vygenerované pdfgen na tom zázname sa najprv odstránia. Manuálne nahrané PDF sa nikdy nedotýkajú."

msgid "Last Updated by"
msgstr "Naposledy aktualizoval"

msgid "Last Updated on"
msgstr "Naposledy aktualizované"

msgid "List Item Fields"
msgstr "Polia položky zoznamu"

msgid "Mapping"
msgstr "Mapovanie"

msgid "Mappings"
msgstr "Mapovania"

