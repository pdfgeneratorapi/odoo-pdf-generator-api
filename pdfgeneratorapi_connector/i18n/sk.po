msgstr "Zobrazovaný názov"

msgid "Document"
msgstr "Dokument"

msgid "Dotted Odoo attribute path from the dataset's model (or from the parent list's iterated record, for children). Ignored when Expression is set."
msgstr "Bodkovaná cesta atribútov Odoo od modelu dátovej sady (alebo od iterovaného záznamu nadradeného zoznamu pre potomkov). Ignorované, keď je nastavený Výraz."

msgid "Dotted path in the template JSON. Relative to the parent list for children."
msgstr "Bodkovaná cesta v JSON šablóny. Relatívna k nadradenému zoznamu pre potomkov."

msgid "Editor URL"
msgstr "URL editora"

msgid "Editor Web URL"
msgstr "Webová URL editora"

