msgstr "Não foi possível carregar os dados do modelo (HTTP %s): %s"

msgid "Could not load the editor (HTTP %s): %s"
msgstr "Não foi possível carregar o editor (HTTP %s): %s"

msgid "Create"
msgstr "Criar"

