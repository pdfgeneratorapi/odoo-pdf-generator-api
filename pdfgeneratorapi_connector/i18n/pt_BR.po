msgstr "Conectado ao espaço de trabalho: %s"

msgid "Connection"
msgstr "Conexão"

msgid "Connection failed (HTTP %s): %s"
msgstr "Falha na conexão (HTTP %s): %s"

msgid "Control what happens to previously-generated PDFs when a user clicks Generate again on the same record."
msgstr "Controla o que acontece com PDFs gerados anteriormente quando o usuário clica em «Gerar» novamente no mesmo registro."

msgid "Could not create template (HTTP %s): %s"
msgstr "Não foi possível criar o modelo (HTTP %s): %s"

msgid "Could not load sample template data (HTTP %s): %s"
msgstr "Não foi possível carregar os dados de amostra do modelo (HTTP %s): %s"

