msgstr "Ajustes de configuración"

msgid "Connected to workspace: %s"
msgstr "Conectado al espacio de trabajo: %s"

msgid "Connection"
msgstr "Conexión"

msgid "Connection failed (HTTP %s): %s"
msgstr "Error de conexión (HTTP %s): %s"

msgid "Control what happens to previously-generated PDFs when a user clicks Generate again on the same record."
msgstr "Controla qué ocurre con los PDF generados previamente cuando el usuario pulsa «Generar» de nuevo en el mismo registro."

msgid "Could not create template (HTTP %s): %s"
msgstr "No se pudo crear la plantilla (HTTP %s): %s"

msgid "Could not load sample template data (HTTP %s): %s"
msgstr "No se pudieron cargar los datos de muestra de la plantilla (HTTP %s): %s"

