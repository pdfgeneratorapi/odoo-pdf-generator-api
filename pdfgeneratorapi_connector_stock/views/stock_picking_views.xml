<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_pdfgen" model="ir.ui.view">
        <field name="name">stock.picking.form.pdfgen</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_pdfgen_wizard"
                        type="object"
                        string="Generate custom PDF"
                        class="oe_highlight"
                        invisible="not pdfgen_configured"/>
                <field name="pdfgen_configured" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_picking_list_pdfgen" model="ir.ui.view">
        <field name="name">stock.picking.list.pdfgen</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button name="action_open_pdfgen_wizard_from_list"
                            type="object"
                            string="Generate custom PDF"
                            class="btn-primary"/>
                    <button name="action_view_pdfgen_async_jobs_from_list"
                            type="object"
                            string="View Async Jobs"
                            class="btn-secondary"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
