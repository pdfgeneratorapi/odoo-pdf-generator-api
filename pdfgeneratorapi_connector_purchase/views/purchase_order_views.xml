<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_pdfgen" model="ir.ui.view">
        <field name="name">purchase.order.form.pdfgen</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_pdfgen_wizard"
                        type="object"
                        string="Generate custom PDF"
                        class="oe_highlight"
                        invisible="not pdfgen_configured"/>
                <field name="pdfgen_configured" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
